# ─────────────────────────────────────────────────────────────────
# Talent Hub — Example Environment Variables
# Copy this file to .env and fill in the values. Never commit .env.
# ─────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
# PostgreSQL connection string (example format)
# Replace <DB_USER>, <DB_PASS>, <HOST>, <PORT>, <DB_NAME> accordingly.
DATABASE_URL="postgresql://<DB_USER>:<DB_PASS>@<HOST>:5432/<DB_NAME>?sslmode=require&channel_binding=require"

# ── Session ───────────────────────────────────────────────────────
# Must be a long, random string (>=32 chars). Generate with:
#   openssl rand -base64 32
SESSION_SECRET="your-32+char-session-secret-here"

# ── Admin seed credentials (local/dev only) ─────────────────────────
# Used by `pnpm db:seed`. Change before deploying to production.
ADMIN_USERNAME="talent-hub-admin"
ADMIN_PASSWORD="change-this-before-deploy"

# ── EmailJS (server-side) ─────────────────────────────────────────
# EmailJS uses a public key and a private access token. Keep the private
# key secret and never expose it client-side.
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_PRIVATE_KEY=your_emailjs_private_key
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_TEMPLATE_ID=your_emailjs_template_id

# Add any additional environment variables your deployment requires below.# ─────────────────────────────────────────────────────────────────
